[run]
source = app,mcp_server,utils
omit =
    */tests/*
    */__pycache__/*
    */__init__.py
    */sandbox/*

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == "__main__":
    if TYPE_CHECKING:
    @abstractmethod

precision = 2
show_missing = True

[html]
directory = htmlcov
